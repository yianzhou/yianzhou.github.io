{
  "Post URL": {
    "prefix": "post",
    "body": ["{% post_url $1 %}"],
    "description": ""
  },
  "Table of contents": {
    "prefix": "toc",
    "body": "<!-- prettier-ignore -->\n* Do not remove this line (it will not be displayed)\n{:toc}\n",
    "description": ""
  },
  "Mermaid": {
    "prefix": "mermaid",
    "body": "<div class=\"mermaid\">\n</div>",
    "description": ""
  },
  "Markdown table": {
    "prefix": "table",
    "body": "| 表头   | 表头   |\n| ------ | ------ |\n| 单元格 | 单元格 |\n| 单元格 | 单元格 |",
    "description": ""
  },
  "Image URL": {
    "prefix": "image",
    "body": "![img](/assets/images/$1)",
    "description": ""
  }
}
